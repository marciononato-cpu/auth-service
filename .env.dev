# === Configurações Isoladas para Docker (Dev/Staging) ===
# Este arquivo é usado APENAS pelo Docker, não interfere na produção atual.

RAILS_ENV=production
PORT=3000

# Banco de Dados (Dev) - Porta 5433 no Host
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=auth_dev_db
DATABASE_USER=auth_dev
DATABASE_PASSWORD=dev_secure_password_123

# Redis (Dev) - Porta 6380 no Host
REDIS_URL=redis://redis:6379/0
